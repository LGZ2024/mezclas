<div class="modal fade" id="modalRanchoDsa" tabindex="-1" role="dialog" aria-labelledby="miModalLabel" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="modalRanchoDsaLabel" style="color: black;">Gestión de Rancho DSA</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Cerrar">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <form id="formRanchoDsa">
          <input type="hidden" id="id_rancho_dsa" name="id">

          <div class="form-group">
            <label for="id_rancho">Rancho</label>
            <select class="form-control" id="id_rancho" name="id_rancho" required>
              <option value="">Seleccione un rancho</option>
              <% if (typeof ranchos !=='undefined' ) { %>
                <% ranchos.forEach(rancho=> { %>
                  <option value="<%= rancho.id %>">
                    <%= rancho.rancho %>
                  </option>
                  <% }) %>
                    <% } %>
            </select>
          </div>
          <div class="form-group">
            <label for="nombre_rancho_dsa">Nombre del Rancho DSA</label>
            <input type="text" class="form-control" id="nombre_rancho_dsa" name="nombre_rancho_dsa" placeholder="Nombre del rancho DSA" required>
          </div>
          <div class="form-group">
            <label for="numero_rancho_dsa">Número de Rancho DSA</label>
            <input type="number" class="form-control" id="numero_rancho_dsa" name="numero_rancho_dsa" placeholder="Número del rancho DSA" required min="1">
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
        <button type="submit" form="formRanchoDsa" class="btn btn-primary" id="btnRegistrar">Guardar</button>
      </div>
    </div>
  </div>
</div>
