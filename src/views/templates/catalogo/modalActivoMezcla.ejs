<div class="modal fade" id="modalActivoMezcla" tabindex="-1" role="dialog" aria-labelledby="miModalLabel"
    aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalActivoMezclaLabel" style="color: black;">Gestión de Activo</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="formActivoMezcla">
                    <input type="hidden" id="id_activo" name="id">
                    <div class="form-group">
                        <label for="nombre">Nombre</label>
                        <input type="text" class="form-control" id="nombre" name="nombre"
                            placeholder="Nombre del activo" maxlength="50" required>
                    </div>
                    <div class="form-group">
                        <label for="codigo">Código</label>
                        <input type="text" class="form-control" id="codigo" name="codigo"
                            placeholder="Código del activo" maxlength="20" required>
                    </div>
                    <div class="form-group">
                        <label for="tipo">Tipo</label>
                        <select class="form-control" id="tipo" name="tipo" required>
                            <option value="">Seleccionar tipo</option>
                            <option value="PRINCIPAL">Principal</option>
                            <option value="SECUNDARIO">Secundario</option>
                            <option value="BIOESTIMULANTE">Bioestimulante</option>
                            <option value="BIOLOGICOS">Biologicos</option>
                            <option value="COADYUVANTE">Coadyuvante</option>
                            <option value="MACRO">Macronutriente</option>
                            <option value="MICRO">Micro</option>
                            <option value="OTRO">Otro</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="unidad">Unidad</label>
                        <select class="form-control" id="unidad" name="unidad" required>
                            <option value="">Seleccionar unidad</option>
                            <option value="KG">KG</option>
                            <option value="LITRO">LITRO</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <div class="custom-control custom-checkbox">
                            <input type="checkbox" class="custom-control-input" id="es_principal" name="es_principal"
                                value="1">
                            <label class="custom-control-label" for="es_principal">Marcar como activo principal</label>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                <button type="submit" form="formActivoMezcla" class="btn btn-primary" id="btnRegistrar">Guardar</button>
            </div>
        </div>
    </div>
</div>