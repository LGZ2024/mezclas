<div class="modal fade" id="modalRancho" tabindex="-1" role="dialog" aria-labelledby="miModalLabel" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="modalRanchoLabel" style="color: black;">Gestión de Rancho</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Cerrar">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <form id="formRancho">
          <input type="hidden" id="id_rancho" name="id">

          <div class="form-group">
            <label for="id_empresa">Empresa</label>
            <select class="form-control" id="id_empresa" name="id_empresa" required>
              <option value="">Seleccione una empresa</option>
              <% if (typeof empresas !=='undefined' ) { %>
                <% empresas.forEach(empresa=> { %>
                  <option value="<%= empresa.id %>">
                    <%= empresa.nombre_comercial %>
                  </option>
                  <% }) %>
                    <% } %>
            </select>
          </div>
          <div class="form-group">
            <label for="rancho">Nombre del Rancho</label>
            <input type="text" class="form-control" id="rancho" name="rancho" placeholder="Nombre del rancho" required>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
        <button type="submit" form="formRancho" class="btn btn-primary" id="btnRegistrar">Guardar</button>
      </div>
    </div>
  </div>
</div>